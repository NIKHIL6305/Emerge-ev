rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    function isValidChargingSession(data) {
      return data.keys().hasAll(['userId', 'date', 'location', 'energyDelivered']) &&
             data.keys().size() == 4 &&
             data.userId == request.auth.uid &&
             data.date == request.time &&
             data.location is string &&
             data.location.size() <= 100 &&
             (data.energyDelivered is number);
    }

    match /charging_sessions/{sessionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidChargingSession(incoming());
      
      allow update: if false; // immutable record of charging session
      
      allow delete: if false; // cannot delete charging history
    }
  }
}
